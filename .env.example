# ChemCrow 公开仓库复现环境变量模板
# 使用说明：
# 1. 复制本文件为 .env 后再填写真实值
# 2. 本文件中的“本次复现已实际使用”表示当前阶段证据链里已经直接用到
# 3. 本文件中的“可选”表示当前仓库可支持，但当前阶段证据链未依赖该变量形成主结论

# 本次复现已实际使用：Qwen 的 OpenAI-compatible 接口 key
OPENAI_API_KEY=your-qwen-compatible-api-key

# 本次复现已实际使用：Qwen 的 OpenAI-compatible base URL
OPENAI_API_BASE=https://dashscope.aliyuncs.com/compatible-mode/v1

# 本次复现已实际使用：主模型，当前证据链使用固定快照以增强可复现性
CHEMCROW_MODEL=qwen3.5-plus-2026-02-15

# 本次复现已实际使用：工具模型，当前与主模型保持一致
CHEMCROW_TOOLS_MODEL=qwen3.5-plus-2026-02-15

# 本次复现已实际使用：摘要模型，当前与主模型保持一致
CHEMCROW_SUMMARY_MODEL=qwen3.5-plus-2026-02-15

# 本次复现已实际使用：RXN4Chem API key
RXN4CHEM_API_KEY=your-rxn4chem-api-key

# 本次复现已实际使用：RXN4Chem project id
RXN4CHEM_PROJECT_ID=your-rxn4chem-project-id

# 本次复现已实际使用：SerpApi key，用于 WebSearch
SERP_API_KEY=your-serpapi-key

# 可选：ChemSpace API key，用于价格查询和部分分子表示转换补充路径
CHEMSPACE_API_KEY=

# 可选：Semantic Scholar API key，用于 LiteratureSearch 的完整链路
SEMANTIC_SCHOLAR_API_KEY=
