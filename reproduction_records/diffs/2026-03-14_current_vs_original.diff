++class PatentCheck(BaseTool):
++    name = "PatentCheck"
++    description = "Input SMILES, returns if molecule is patented. You may also input several SMILES, separated by a period."
++
++    @staticmethod
++    def _surechembl_exact_search(smiles: str) -> bool:
++        canonical = canonical_smiles(smiles)
++        if canonical == "Invalid SMILES string":
++            raise ValueError("Invalid SMILES string")
++
++        payload = {
++            "StructureSearchRequest": {
++                "struct": canonical,
++                "structSearchType": "exact",
++                "maxResults": 5,
++            }
++        }
++        response = requests.post(
++            "https://www.surechembl.org/api/search/structure",
++            json=payload,
++            timeout=30,
++        )
++        response.raise_for_status()
++        search_hash = response.json().get("data", {}).get("hash")
++        if not search_hash:
++            raise ValueError("No search hash returned")
++
++        for _ in range(5):
++            sleep(2)
++            results = requests.get(
++                f"https://www.surechembl.org/api/search/{search_hash}/results",
++                params={"page": 1, "max_results": 5},
++                timeout=30,
++            )
++            results.raise_for_status()
++            payload = results.json().get("data", {})
++            result_data = payload.get("results")
++            if result_data is not None:
++                return result_data.get("total_hits", 0) > 0
++        raise ValueError("Patent lookup timed out")
++
++    def _run(self, smiles: str) -> str:
++        """Checks if compound is patented. Give this tool only one SMILES string"""
++        if is_multiple_smiles(smiles):
++            smiles_list = split_smiles(smiles)
++        else:
++            smiles_list = [smiles]
++        try:
++            output_dict = {}
++            for smi in smiles_list:
++                try:
++                    r = molbloom.buy(smi, canonicalize=True, catalog="surechembl")
++                except Exception:
++                    r = self._surechembl_exact_search(smi)
++                if r:
++                    output_dict[smi] = "Patented"
++                else:
++                    output_dict[smi] = "Novel"
++            return str(output_dict)
++        except:
++            return "Invalid SMILES string"
++
++    async def _arun(self, query: str) -> str:
++        """Use the tool asynchronously."""
++        raise NotImplementedError()
