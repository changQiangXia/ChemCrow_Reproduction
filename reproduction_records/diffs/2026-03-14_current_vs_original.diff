+            ]
+        else:
+            in_stock = True
+            children = []
+
+        return {
+            "type": "mol",
+            "route_metadata": {"created_at_iteration": 1, "is_solved": True},
+            "hide": False,
+            "smiles": path["smiles"],
+            "is_chemical": True,
+            "in_stock": in_stock,
+            "children": children,
+        }
