++def paper_scraper(search: str, pdir: str = "query", semantic_scholar_api_key: str = None) -> dict:
++    if paperscraper is None:
++        return {}
++    try:
++        return paperscraper.search_papers(
++            search,
++            pdir=pdir,
++            semantic_scholar_api_key=semantic_scholar_api_key,
++        )
++    except KeyError:
++        return {}
